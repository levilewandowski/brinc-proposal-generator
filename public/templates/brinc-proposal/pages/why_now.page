pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: logo
    elementType: text
    bounds: [60, 28, 120, 24]
    content:
      text: |
        <p><span style="font-size:14px; color:$primary; letter-spacing:3px;"><strong>BRINC</strong></span></p>
      fontFamily: "Liter"
      wrap: false
      align: [left, middle]
  - elementId: page-num
    elementType: text
    bounds: [1180, 28, 40, 24]
    content:
      style: "$caption"
      text: |
        <p>02</p>
      wrap: false
      align: [right, middle]
  - elementId: title
    elementType: text
    bounds: [60, 70, 600, 45]
    content:
      style: "$title"
      fontSize: 32
      text: |
        <p><strong>Why This, Why Now</strong></p>
      wrap: false
      align: [left, middle]
  - elementId: accent-line
    elementType: shape
    bounds: [60, 120, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: context-body
    elementType: text
    bounds: [60, 150, 700, 240]
    content:
      style: "$body"
      text: |
        <p>{{STRATEGIC_CONTEXT_PARA1}}</p>
        <p style="margin-top:16px">{{STRATEGIC_CONTEXT_PARA2}}</p>
      align: [left, top]
  - elementId: opportunity-box
    elementType: shape
    bounds: [820, 150, 400, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$lightgray"
  - elementId: opportunity-title
    elementType: text
    bounds: [845, 165, 350, 30]
    content:
      text: |
        <p><span style="font-size:14px; color:$primary; letter-spacing:2px;"><strong>THE OPPORTUNITY</strong></span></p>
      fontFamily: "Liter"
      wrap: false
      align: [left, middle]
  - elementId: opportunity-body
    elementType: text
    bounds: [845, 200, 350, 130]
    content:
      style: "$body"
      fontSize: 16
      text: |
        <p>{{OPPORTUNITY_TEXT}}</p>
      align: [left, top]
  - elementId: divider
    elementType: shape
    bounds: [60, 420, 1160, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$midgray"
  - elementId: stat1-num
    elementType: text
    bounds: [60, 450, 280, 60]
    content:
      style: "$stat"
      text: |
        <p><strong>{{STAT_1_VALUE}}</strong></p>
      wrap: false
      align: [left, bottom]
  - elementId: stat1-label
    elementType: text
    bounds: [60, 515, 280, 60]
    content:
      style: "$body"
      fontSize: 16
      text: |
        <p>{{STAT_1_LABEL}}</p>
      align: [left, top]
  - elementId: stat2-num
    elementType: text
    bounds: [380, 450, 280, 60]
    content:
      style: "$stat"
      text: |
        <p><strong>{{STAT_2_VALUE}}</strong></p>
      wrap: false
      align: [left, bottom]
  - elementId: stat2-label
    elementType: text
    bounds: [380, 515, 280, 60]
    content:
      style: "$body"
      fontSize: 16
      text: |
        <p>{{STAT_2_LABEL}}</p>
      align: [left, top]
  - elementId: stat3-num
    elementType: text
    bounds: [700, 450, 280, 60]
    content:
      style: "$stat"
      text: |
        <p><strong>{{STAT_3_VALUE}}</strong></p>
      wrap: false
      align: [left, bottom]
  - elementId: stat3-label
    elementType: text
    bounds: [700, 515, 280, 60]
    content:
      style: "$body"
      fontSize: 16
      text: |
        <p>{{STAT_3_LABEL}}</p>
      align: [left, top]