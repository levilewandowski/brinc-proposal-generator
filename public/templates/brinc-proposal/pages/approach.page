pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: logo
    elementType: text
    bounds: [60, 28, 120, 24]
    content:
      text: |
        <p><span style="font-size:14px; color:$primary; letter-spacing:3px;"><strong>BRINC</strong></span></p>
      fontFamily: "Liter"
      wrap: false
      align: [left, middle]
  - elementId: page-num
    elementType: text
    bounds: [1180, 28, 40, 24]
    content:
      style: "$caption"
      text: |
        <p>04</p>
      wrap: false
      align: [right, middle]
  - elementId: title
    elementType: text
    bounds: [60, 70, 600, 45]
    content:
      style: "$title"
      fontSize: 32
      text: |
        <p><strong>How This Works</strong></p>
      wrap: false
      align: [left, middle]
  - elementId: accent-line
    elementType: shape
    bounds: [60, 120, 60, 3]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: phase1-box
    elementType: shape
    bounds: [60, 160, 265, 320]
    shapeName: rect
    fill:
      type: solid
      color: "$lightgray"
  - elementId: phase1-num
