{
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    {
      "source": "/google/callback",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[[...route]]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
