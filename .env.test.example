# ═══════════════════════════════════════════════════════════
#  PPTX Diagnostics Test Runner — Environment Variables
#  Copy to .env.test and fill in your values (never commit .env.test)
# ═══════════════════════════════════════════════════════════

# Your Google refresh token (from browser localStorage → googleTokens.refresh_token)
# This is obtained after first OAuth login — it's a long-lived token.
GOOGLE_REFRESH_TOKEN=

# Vercel deployment URL (update if you have a custom domain)
DEPLOYMENT_URL=https://brinc-proposal-generator.vercel.app

# Optional: override retry behavior
# MAX_RETRIES=30
# RETRY_DELAY_MS=15000
